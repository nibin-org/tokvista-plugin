# GitHub token used by relay publish/version-history/preview GitHub reads.
# Optional if every project entry provides its own githubToken.
TOKVISTA_GITHUB_TOKEN=

# Required JSON map of publish targets.
# Generate a new publishKey for every real deployment and rotate it if it was ever exposed.
TOKVISTA_PROJECTS='{"project-alpha":{"publishKey":"replace-with-strong-secret","owner":"nibin-org","repo":"tokvista","branch":"main","path":"tokens.json"}}'

# Optional relay runtime settings.
PORT=8787
DATA_DIR=relay/data

# Public preview page base URL used for links returned by publish/history APIs.
# Use your deployed preview page, for example https://your-app.vercel.app/preview
TOKVISTA_PREVIEW_BASE_URL=https://tokvista-plugin.vercel.app/preview

# Extra comma-separated HTTPS origins allowed for /api/preview?source=...
# raw.githubusercontent.com is always allowed automatically.
TOKVISTA_ALLOWED_PREVIEW_SOURCE_ORIGINS=

# Optional Groq settings for /api/ai-guide.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional local-only override for npm run dev:stack.
# Example: D:\workspace\tokvista\demo
TOKVISTA_DEMO_DIR=
